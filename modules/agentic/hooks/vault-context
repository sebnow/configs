#!/usr/bin/env bash
set -euo pipefail

command -v md &>/dev/null || exit 0

vault="${XDG_DATA_HOME:-$HOME/.local/share}/agents/vault"
if [[ ! -d "$vault" ]]; then
  exit 0
fi

descriptions=""
while IFS= read -r note; do
  desc=$(md 'frontmatter.description' < "$note" 2>/dev/null)
  if [[ -n "$desc" ]]; then
    name=$(basename "$note" .md)
    tags=$(md 'frontmatter.tags' < "$note" 2>/dev/null)
    if [[ "$tags" != "null" ]]; then
      descriptions+="- [[$name]]: $desc (tags: $(echo "$tags" | paste -sd, -))"$'\n'
    else
      descriptions+="- [[$name]]: $desc"$'\n'
    fi
  fi
done < <(find "$vault" -name '*.md' -not -path '*/archive/*' | sort)

if [[ -z "$descriptions" ]]; then
  exit 0
fi

context="The following vault notes are available. Use /agent-vault recall to read relevant notes.
$descriptions"

jq -n --arg ctx "$context" '{
  hookSpecificOutput: {
    hookEventName: "SessionStart",
    additionalContext: $ctx
  }
}'
