#!/usr/bin/env bash
# Stop-event hook: block session end when the working copy is not clean.
#
# If the agent forgets to commit or squash @ before stopping, the user's
# next file edit will auto-commit into the dirty @ without any warning.
# This hook fires at session end and, when the working copy is dirty, emits
# decision:"block" so Claude Code re-fires the agent's turn with an
# actionable prompt before the session actually ends.
#
# decision:"block" is required because a bare systemMessage is advisory
# (terminal-only); only block causes the reason to be injected into the
# agent's conversation so it can correct the state.
#
# stdin  : Claude Code Stop event JSON (consumed and discarded)
# stdout : {"decision":"block","reason":string,"systemMessage":string}
#        |   on unclean working copy
#        | (empty)   on clean or no-repo cwd
# exit   : 0 always
set -euo pipefail

emit_block() {
  local reason="$1" status="$2"
  jq -n --arg r "$reason" --arg s "$status" \
    '{decision:"block", reason:$r, systemMessage:$s}'
  exit 0
}

main() {
  # Consume stdin; no fields needed from the Stop event.
  cat > /dev/null

  # Probe jj first. jj walks up from $PWD to find the repo, so no manual
  # directory traversal is needed. Any non-zero exit means no jj repo here.
  if jj_out=$(jj status 2>/dev/null); then
    # @ is clean when its working-copy line contains "(empty)".
    # Untracked-only changes still show "(empty)" here; that matches jj's
    # own model where untracked files are not part of @.
    wc_line=$(printf '%s' "$jj_out" | grep "^Working copy.*(@)" || true)
    if [[ -n "$wc_line" ]] && ! printf '%s' "$wc_line" | grep -q "(empty)"; then
      emit_block \
        "Working copy @ has uncommitted changes. Run \`jj status\` to inspect, then \`jj commit -m MSG\` to seal the change (or \`jj squash\` to fold it into an existing description) before ending the session. Otherwise the user's next file edit will auto-commit into the dirty @." \
        "vcs-working-copy-guard: jj @ not empty"
    fi
    exit 0
  fi

  # Fall back to git. git also walks up from $PWD.
  if git_out=$(git status --porcelain 2>/dev/null); then
    if [[ -n "$git_out" ]]; then
      emit_block \
        "Git working tree is not clean. Run \`git status\` to inspect, then \`git commit -m MSG\` to seal the change (or \`git stash\` to set it aside) before ending the session. Otherwise uncommitted work will remain exposed." \
        "vcs-working-copy-guard: git working tree not clean"
    fi
  fi
  # No repo found or clean state: emit nothing.
}

# On any unexpected failure still exit 0 — the hook contract requires it.
main || true
exit 0
