#!/usr/bin/env bash
set -euo pipefail

cwd=$(jq -r '.cwd // empty')
if [[ -z "$cwd" ]]; then
  exit 0
fi

vcs=""
commits=""

if commits=$(cd "$cwd" && jj log -r 'ancestors(@-, 5)' -T 'change_id.short() ++ " " ++ description.first_line() ++ "\n"' --no-graph 2>/dev/null); then
  vcs="jujutsu"
elif commits=$(cd "$cwd" && git log --oneline -5 2>/dev/null); then
  vcs="git"
else
  exit 0
fi

jq -n --arg vcs "$vcs" --arg commits "$commits" '{
  hookSpecificOutput: {
    hookEventName: "SessionStart",
    additionalContext: "This project uses \($vcs) for version control. Use the \($vcs) workflow for all VCS operations.\n\nRecent commits:\n\($commits)"
  }
}'
