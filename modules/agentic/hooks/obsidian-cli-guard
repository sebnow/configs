#!/usr/bin/env bash
# PreToolUse hook: block obsidian-cli misuse and direct filesystem manipulation
# of vault paths. See .agents/prd-obsidian.md for the full pattern catalogue.
#
# stdin  : {"tool_name":"Bash","tool_input":{"command":string},"cwd":string,...}
# stdout : {"hookSpecificOutput":{"hookEventName":"PreToolUse",
#            "permissionDecision":"deny",
#            "permissionDecisionReason":string}}
#          | {}   // no decision; defer to permissions
# exit   : 0 on every invocation
set -euo pipefail

emit_decision() {
  local decision="$1" reason="$2"
  jq -n --arg d "$decision" --arg r "$reason" \
    '{hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:$d,permissionDecisionReason:$r}}'
  exit 0
}

emit_defer() {
  printf '{}\n'
  exit 0
}

# _VAULT_ROOTS_CACHE — script-level cache populated by load_vault_roots, read
# by in_vault. Defined at script scope (not inside the loader) because
# in_vault is called from command-substitution contexts in token loops and
# any cache stored inside vault_roots itself would live in the subshell.
_VAULT_ROOTS_CACHE=""

# load_vault_roots — populates _VAULT_ROOTS_CACHE with zero or more absolute
# vault paths, one per line. Must be called exactly once at the start of main
# so that in_vault calls in token loops do not re-spawn obsidian-cli per token.
# When OBSIDIAN_GUARD_VAULT_ROOTS is set (even empty), it wins.
# Otherwise shells out to obsidian-cli; on any failure leaves the cache empty.
# See .agents/prd-obsidian.md "vault-roots" contract.
load_vault_roots() {
  local raw_roots
  if [[ -v OBSIDIAN_GUARD_VAULT_ROOTS ]]; then
    raw_roots="$OBSIDIAN_GUARD_VAULT_ROOTS"
  else
    # Defer gracefully if obsidian-cli is unavailable, fails, or hangs.
    # The 2s timeout bounds latency when Obsidian is unreachable so a wedged
    # instance does not block every Bash tool call in the agent session.
    # `timeout` exits 124 on timeout; the `if !` catches it the same way as a
    # non-zero exit from obsidian-cli itself.
    local raw
    if ! raw=$(timeout 2s obsidian-cli vaults verbose 2>/dev/null); then
      return 0
    fi
    # "obsidian-cli vaults verbose" emits tab-separated lines: <name>\t<path>
    # with no header row. Using -F'\t' avoids truncating paths that contain spaces,
    # which whitespace-based splitting ($2 without -F) would silently break.
    if ! raw_roots=$(printf '%s\n' "$raw" | awk -F'\t' '{print $2}' | sed 's|/$||'); then
      return 0
    fi
  fi
  # Canonicalise each root so symlinked vault paths match candidates that
  # normalise_path has resolved via realpath -m. Without this, a vault root
  # supplied as ~/Vaults/X (a symlink) never matches a candidate that resolves
  # to /mnt/data/x/... — the prefix check sees the unresolved root and fails.
  # realpath -m tolerates non-existent paths (returning them with .. and .
  # collapsed) so missing vault directories degrade to literal comparison.
  local root canonical=""
  while IFS= read -r root; do
    [[ -z "$root" ]] && continue
    local resolved
    if ! resolved=$(realpath -m -- "$root" 2>/dev/null); then
      resolved="$root"
    fi
    canonical+="$resolved"$'\n'
  done <<< "$raw_roots"
  _VAULT_ROOTS_CACHE="${canonical%$'\n'}"
}

# normalise_path resolves a raw path token from the inspected command.
# Strips surrounding matching quotes, expands leading ~/, resolves relative
# paths against $cmd_cwd, then collapses .. and . via realpath -m.
normalise_path() {
  local raw="$1" cwd="$2"
  # Strip surrounding double or single quotes.
  if [[ "$raw" == \"*\" ]]; then
    raw="${raw:1:${#raw}-2}"
  elif [[ "$raw" == \'*\' ]]; then
    raw="${raw:1:${#raw}-2}"
  fi
  # Match and expand a literal ~/ prefix from the inspected command string.
  # SC2088: tilde not expanding in quotes is intentional — we match the literal
  # characters ~/ that an agent typed, then expand to $HOME ourselves.
  # shellcheck disable=SC2088
  if [[ "$raw" == "~/"* ]]; then
    raw="$HOME/${raw:2}"
  fi
  # Resolve relative paths against the command's cwd.
  if [[ "$raw" != /* ]]; then
    raw="$cwd/$raw"
  fi
  realpath -m -- "$raw" 2>/dev/null || printf '%s' "$raw"
}

# in_vault returns 0 (true) when the given absolute path lies inside any of the
# vault roots. Containment requires equality or prefix <root>/ to avoid
# false-positives on sibling directories that share a name prefix.
# Reads from the script-level _VAULT_ROOTS_CACHE populated by load_vault_roots;
# never spawns a subprocess.
in_vault() {
  local candidate="$1"
  [[ -z "$_VAULT_ROOTS_CACHE" ]] && return 1
  local root
  while IFS= read -r root; do
    [[ -z "$root" ]] && continue
    if [[ "$candidate" == "$root" || "$candidate" == "$root/"* ]]; then
      return 0
    fi
  done <<< "$_VAULT_ROOTS_CACHE"
  return 1
}

main() {
  if ! input=$(cat); then
    emit_defer
  fi
  if ! cmd=$(printf '%s' "$input" | jq -r '.tool_input.command // empty'); then
    emit_defer
  fi
  [[ -n "$cmd" ]] || emit_defer

  local cmd_cwd
  if ! cmd_cwd=$(printf '%s' "$input" | jq -r '.cwd // empty'); then
    cmd_cwd=""
  fi
  [[ -n "$cmd_cwd" ]] || cmd_cwd="$(pwd)"

  # Populate the vault-roots cache once per hook invocation so that token
  # loops below can call in_vault repeatedly without re-spawning obsidian-cli.
  load_vault_roots

  # obsidian-cli must appear at a segment start so quoted uses like
  # `echo "obsidian-cli create --help"` (where it is an argument to another
  # command) are not matched. `\b` prevents `obsidian-cli-guard` or any
  # other hyphenated binary from triggering the pattern.
  #
  # After the subcommand token (`\S+`), `[^;&|()]*` allows key=value arguments
  # before the offending flag but stops at shell operators (`;`, `&`, `|`, `(`,
  # `)`) so flags on a chained command like `obsidian-cli create path=X && ls -la`
  # are not mistaken for flags on obsidian-cli itself. `\s+-` anchors the
  # dash-prefixed token to a whitespace boundary so a flag embedded in a
  # key=value string is not caught.
  local pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+\S+[^;&|()]*\s+-"

  if printf '%s' "$cmd" | grep -qP "$pattern"; then
    emit_decision "deny" "obsidian-cli does not parse GNU-style flags — dash-prefixed tokens such as --help or --vault are silently ignored, not treated as options. On the create subcommand this causes the CLI to create Untitled.md in the vault and return a misleading success message instead of failing. Use positional key=value arguments for all options (e.g. vault=MyVault path=Notes/Foo.md). Run obsidian-cli help <subcommand> to see the accepted key=value parameters for a given subcommand."
  fi

  # When `obsidian-cli create` is called without any of the recognised target
  # arguments (path=, name=, or file=), the CLI silently writes Untitled.md
  # instead of failing. The negative lookahead `(?![^|><;&]*(?:^|\s)(?:path|name|file)=)`
  # scans only to the first shell operator boundary (`[^|><;&]*`) so that target
  # tokens on a chained command (e.g. `obsidian-cli create | grep path=X`) are
  # not mistaken for a target on this create call. `2>&1` contains `>` which
  # terminates the scan correctly — that redirection is not a target token.
  # `(?:^|\s)` is used instead of `\b` because `\b` matches at a quote-letter
  # transition, so `path=` inside a quoted value like content="path=fake" would
  # be mistaken for a real target argument.
  local no_target_pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+create\b(?![^|><;&]*(?:^|\s)(?:path|name|file)=)"

  if printf '%s' "$cmd" | grep -qP "$no_target_pattern"; then
    emit_decision "deny" "obsidian-cli create requires a target argument: pass path=<vault-relative-path> (e.g. path=Notes/Foo.md). Without path=, name=, or file=, the CLI writes Untitled.md to the vault root and reports success, causing a spurious file that must be manually deleted."
  fi

  # When both name= and path= are supplied and either value contains a dot,
  # the CLI treats path= as a directory prefix and name= as the filename.
  # A dot in the name= value (typical of Foo.md) then nests the file inside a
  # directory whose name is the dot-bearing string, producing unexpected paths
  # like Notes/Foo.md/Foo.md. The same nesting occurs when path= itself contains
  # a dot. The value-with-dot pattern uses alternation to handle quoted values
  # ("Foo.md"), single-quoted values, and bare unquoted values separately so
  # that the leading quote character is consumed before scanning for a dot,
  # avoiding false matches on the quote itself.
  local name_path_dot_pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+create\b(?=[^|><;&]*(?:^|\s)name=)(?=[^|><;&]*(?:^|\s)path=)(?=[^|><;&]*(?:(?:^|\s)name=(?:\"[^\"]*\.[^\"]*\"|'[^']*\.[^']*'|[^\"'\s|><;&]*\.[^\"'\s|><;&]*)|(?:^|\s)path=(?:\"[^\"]*\.[^\"]*\"|'[^']*\.[^']*'|[^\"'\s|><;&]*\.[^\"'\s|><;&]*)))"

  if printf '%s' "$cmd" | grep -qP "$name_path_dot_pattern"; then
    emit_decision "deny" "combining name= and path= with a dot in either value causes directory nesting: the CLI treats path= as a directory prefix and name= as the filename, so a dot-bearing name like Foo.md becomes a subdirectory, producing paths such as Notes/Foo.md/Foo.md. Pass path= alone with the full vault-relative path (e.g. path=Notes/Foo.md) to avoid this."
  fi

  # When `obsidian-cli delete` is called without a target argument (path= or
  # file=), the CLI silently deletes whichever note is currently active in the
  # running Obsidian instance. The deletion is not surfaced until missing content
  # is noticed — a serious, invisible data-loss footgun.
  #
  # The negative lookahead uses `(?:^|\s)` before each key name rather than `\b`
  # to enforce argument-position: `\b` matches at the start of `path=` even
  # inside a quoted value like content="path=fake", because the preceding `"` is
  # a non-word character. Requiring whitespace (or start-of-string) ensures only
  # standalone `path=` and `file=` tokens count as targets.
  local delete_no_target_pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+delete\b(?![^|><;&]*(?:^|\s)(?:path|file)=)"

  if printf '%s' "$cmd" | grep -qP "$delete_no_target_pattern"; then
    emit_decision "deny" "obsidian-cli delete requires a target argument: pass path=<vault-relative-path> (e.g. path=Notes/Foo.md) or file=<name>. Without path= or file=, the CLI silently deletes the active note in the running Obsidian instance — the deletion is invisible until missing content surfaces."
  fi

  # When `obsidian-cli rename` is called with a name= value that does not end
  # in `.md`, the CLI treats the segment after the last dot as the file
  # extension — so "Notes v1.draft" yields extension "draft", and "Bar"
  # (no dot) yields no extension at all. Obsidian cannot index files without
  # the .md extension, and backlinks break silently.
  #
  # The three value alternatives handle double-quoted, single-quoted, and bare
  # unquoted forms separately. The unquoted alternative uses [^"'\s]* rather
  # than \S* so that a quoted value like name="Foo.md" is not consumed as a
  # bare token whose last char is `"` — which would bypass the (?<!\.md) check.
  # (?<!\.md) is a lookbehind anchored to the end of the value (before the
  # closing quote, or before whitespace/end-of-string for unquoted values).
  # (?:^|\s)name= enforces argument position: name= inside a quoted value of
  # another argument (e.g. content="name=ignored") is not matched because the
  # preceding character is `"`, not whitespace.
  local rename_name_md_pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+rename\b[^|><;&]*(?:^|\s)name=(?:\"[^\"]*(?<!\.md)\"|'[^']*(?<!\.md)'|[^\"'\s]*(?<!\.md)(?=\s|$))"

  if printf '%s' "$cmd" | grep -qP "$rename_name_md_pattern"; then
    emit_decision "deny" "obsidian-cli rename requires name= to end with .md. The CLI treats the segment after the last dot as the file extension, so a name like \"Notes v1.draft\" produces extension \"draft\", and a name with no dot at all produces no extension. Without the .md extension Obsidian cannot index the file and backlinks break. Always end the name= value with .md, for example name=\"Notes v1.draft.md\"."
  fi

  # When the first token after `obsidian-cli` is not a recognised subcommand,
  # the CLI silently does nothing useful (or errors in an opaque way). Agents
  # have historically invented subcommands that look plausible but do not exist
  # (e.g. `headings` instead of `outline`, `wikilinks` instead of `links`).
  # Each such invocation wastes one full tool-call turn.
  #
  # A token of the form `[a-z][a-z0-9_]*=` is a key=value argument, which means
  # the subcommand was omitted entirely — that is a different (out-of-scope) case;
  # defer so the agent sees the CLI's own error message.
  #
  # `obsidian-cli` with no following token (help printed by CLI) also defers.
  #
  # The allow-list is space-padded so membership tests use bash substring matching:
  #   [[ " $KNOWN_SUBCOMMANDS " == *" $token "* ]]
  # Sorted alphabetically; reproduced verbatim from `obsidian-cli help` output.
  local KNOWN_SUBCOMMANDS=" aliases append backlinks base:create base:query base:views bases command commands create deadends delete dev:cdp dev:console dev:css dev:debug dev:dom dev:errors dev:mobile dev:screenshot devtools diff eval file files folder folders help history history:list history:open history:read history:restore homepage homepage:read hotkey hotkeys links move open orphans outline plugin plugin:disable plugin:enable plugin:install plugin:reload plugins plugins:enabled plugins:restrict plugin:uninstall prepend properties property:read property:remove property:set random random:read read recents reload rename restart search search:context search:open snippet:disable snippet:enable snippets snippets:enabled tab:open tabs tag tags task tasks theme theme:install themes theme:set theme:uninstall unique unresolved vault vaults version wordcount workspace "

  # Extract the first subcommand-shaped token after `obsidian-cli` at a segment
  # start. \K resets the match start so grep -oP returns only the token itself.
  # (?=[\s)]|$) asserts the token ends at whitespace, `)`, or end-of-string: this
  # excludes key=value first arguments (e.g. `vault=Knowledge` → no match because
  # `vault` is followed by `=`, not a terminator) without a second subprocess and
  # without cross-segment ambiguity. `)` is included so paren-subshell invocations
  # like `(obsidian-cli headings)` are also matched.
  # Synonym table: known agent footguns mapped to the correct subcommand.
  # Additions here should be paired with a new deny-reason test above.
  local candidate suggested_subcommand
  local segment_pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+\K[a-z][a-z0-9:_-]*(?=[\s)]|$)"
  if candidate=$(printf '%s' "$cmd" | grep -oP "$segment_pattern" | head -1) \
      && [[ -n "$candidate" ]] \
      && [[ " $KNOWN_SUBCOMMANDS " != *" $candidate "* ]]; then
    case "$candidate" in
      list-vaults)  suggested_subcommand="vaults" ;;
      headings)     suggested_subcommand="outline" ;;
      wikilinks)    suggested_subcommand="links" ;;
      frontmatter)  suggested_subcommand="properties" ;;
      tag:files)    suggested_subcommand="tag" ;;
      *)            suggested_subcommand="" ;;
    esac

    if [[ -n "$suggested_subcommand" ]]; then
      emit_decision "deny" "\"$candidate\" is not a recognised obsidian-cli subcommand. Did you mean \"$suggested_subcommand\"? Use: obsidian-cli $suggested_subcommand"
    else
      emit_decision "deny" "\"$candidate\" is not a recognised obsidian-cli subcommand. Use: obsidian-cli <subcommand>. Run \`obsidian-cli help\` for the full list."
    fi
  fi

  # P7: filesystem mutation commands whose first non-flag argument lies inside
  # a vault root. The tools listed here — mv, cp, rm, mkdir, rmdir, touch, ln
  # — bypass Obsidian's index and break backlinks when applied to vault files.
  # See .agents/prd-obsidian.md pattern P7.
  local mutation_tools="mv cp rm mkdir rmdir touch ln"
  for tool in $mutation_tools; do
    # Match `<tool>` at a segment start; \K resets so only the argument string
    # is returned by grep -oP.
    local tool_pattern
    tool_pattern="(?:^|[;(]|&&|\|\|)\s*${tool}\b\K.*"
    local args_str
    if args_str=$(printf '%s' "$cmd" | grep -oP "$tool_pattern" | head -1); then
      # Check each non-flag token — covers both source and destination paths.
      # read -ra splits on IFS without triggering pathname expansion; an unquoted
      # `for token in $args_str` would glob-expand tokens like * against the
      # hook's own cwd, producing filesystem paths instead of literal tokens.
      local -a tokens=()
      read -ra tokens <<< "$args_str"
      local token
      for token in "${tokens[@]}"; do
        [[ "$token" == -* ]] && continue
        local norm
        norm=$(normalise_path "$token" "$cmd_cwd")
        if in_vault "$norm"; then
          emit_decision "deny" "Do not use $tool on vault paths — it bypasses Obsidian's index and breaks backlinks. Use \`obsidian-cli\` (\`move\`, \`rename\`, \`delete\`) so backlinks and Templater rules apply."
        fi
      done
    fi
  done

  # P8: redirect operators (> or >>) or tee whose target lies inside a vault root.
  # Writing directly to vault paths bypasses Obsidian's indexing pipeline.
  # See .agents/prd-obsidian.md pattern P8.

  # Check >>/> redirects: extract the path token following >> or >.
  # The pattern captures the first non-whitespace token after the redirect operator.
  local redir_target
  if redir_target=$(printf '%s' "$cmd" | grep -oP '(?:>>|>)\s*\K\S+' | head -1); then
    if [[ -n "$redir_target" ]]; then
      local norm
      norm=$(normalise_path "$redir_target" "$cmd_cwd")
      if in_vault "$norm"; then
        emit_decision "deny" "Do not redirect output into vault paths — writing directly bypasses Obsidian's index. Use \`obsidian-cli create\`/\`append\`/\`prepend\` so the file enters Obsidian's index."
      fi
    fi
  fi

  # Check tee: `tee [-a] <path>` — the path is the last positional argument.
  local tee_pattern
  tee_pattern="(?:^|[;(]|&&|\|\|)\s*tee\b\K.*"
  local tee_args
  if tee_args=$(printf '%s' "$cmd" | grep -oP "$tee_pattern" | head -1); then
    # Same glob-expansion hazard as the P7 and P9 loops — use read -ra.
    local -a tokens=()
    read -ra tokens <<< "$tee_args"
    local token last_positional=""
    for token in "${tokens[@]}"; do
      [[ "$token" == -* ]] && continue
      last_positional="$token"
    done
    if [[ -n "$last_positional" ]]; then
      local norm
      norm=$(normalise_path "$last_positional" "$cmd_cwd")
      if in_vault "$norm"; then
        emit_decision "deny" "Do not use tee into vault paths — writing directly bypasses Obsidian's index. Use \`obsidian-cli create\`/\`append\`/\`prepend\` so the file enters Obsidian's index."
      fi
    fi
  fi

  # P9: text search commands whose search root lies inside a vault root.
  # These bypass Obsidian's index and do not handle Unicode paths or search
  # operators. See .agents/prd-obsidian.md pattern P9.

  # grep/rg: the search root is the first non-flag, non-pattern positional.
  # Pattern: `<tool>` at segment start, then capture all trailing tokens.
  for search_tool in grep rg; do
    local stool_pattern
    stool_pattern="(?:^|[;(]|&&|\|\|)\s*${search_tool}\b\K.*"
    local stool_args
    if stool_args=$(printf '%s' "$cmd" | grep -oP "$stool_pattern" | head -1); then
      # Skip flags; the first non-flag token is the pattern, the second is the root.
      # read -ra prevents glob expansion of tokens like * against the hook's cwd.
      local -a tokens=()
      read -ra tokens <<< "$stool_args"
      local positional_count=0 token
      for token in "${tokens[@]}"; do
        [[ "$token" == -* ]] && continue
        ((positional_count++)) || true
        if [[ $positional_count -eq 2 ]]; then
          local norm
          norm=$(normalise_path "$token" "$cmd_cwd")
          if in_vault "$norm"; then
            emit_decision "deny" "Do not use $search_tool to search vault paths — it bypasses Obsidian's index. Use \`obsidian-cli search\` so the query uses Obsidian's index and search operators."
          fi
          break
        fi
      done
    fi
  done

  # find: the search root is the first non-flag positional (path comes before predicates).
  local find_pattern
  find_pattern="(?:^|[;(]|&&|\|\|)\s*find\b\K.*"
  local find_args
  if find_args=$(printf '%s' "$cmd" | grep -oP "$find_pattern" | head -1); then
    # read -ra prevents glob expansion of tokens like * against the hook's cwd.
    local -a tokens=()
    read -ra tokens <<< "$find_args"
    local token
    for token in "${tokens[@]}"; do
      [[ "$token" == -* ]] && continue
      local norm
      norm=$(normalise_path "$token" "$cmd_cwd")
      if in_vault "$norm"; then
        emit_decision "deny" "Do not use find to search vault paths — it bypasses Obsidian's index. Use \`obsidian-cli search\` so the query uses Obsidian's index and search operators."
      fi
      break
    done
  fi

  # P10: obsidian-cli format=json output piped to jq .path extraction on array
  # elements. obsidian-cli search format=json returns a flat array of path
  # strings, not objects — extracting .path yields null for every entry, causing
  # the agent to proceed as if the search returned no results.
  # See .agents/prd-obsidian.md pattern P10.
  #
  # The pattern requires both conditions on the same pipeline:
  # - left of the pipe: obsidian-cli ... format=json
  # - right of the pipe: jq ... with a .path reference on an array element
  #   (.[].path or .[] | .path or .[] | .["path"])
  local p10_pattern
  p10_pattern='(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b[^|]*\bformat=json\b[^|]*\|[^|]*\bjq\b[^|]*(?:\.\[\]\.path|\.\[\]\s*\|\s*\.path|\.\[\]\s*\|\s*\.\["path"\])'
  if printf '%s' "$cmd" | grep -qP "$p10_pattern"; then
    emit_decision "deny" "\`obsidian-cli format=json\` returns a flat array of path strings, not objects. Use \`jq -r '.[]'\` instead of \`jq -r '.[].path'\` — extracting .path from a string element yields null and the agent proceeds as if the search returned no results."
  fi

  emit_defer
}

main || printf '{}\n'
exit 0
