#!/usr/bin/env bash
# PreToolUse hook: block obsidian-cli invocations that pass GNU-style flags.
#
# obsidian-cli takes positional key=value arguments and does not parse
# dash-prefixed tokens. Unknown flags are silently ignored. On the `create`
# subcommand this causes the CLI to write Untitled.md and return a misleading
# "Created" message instead of failing with an error. This hook intercepts
# the misuse deterministically before the tool runs.
#
# Detection: matches `obsidian-cli` at the start of a pipeline segment
# (start of command, or after `;`, `&&`, `||`, or `(`) followed by a
# subcommand token and then any token beginning with `-`. The segment-start
# anchor prevents false positives where `obsidian-cli` is a quoted string
# inside `echo`/`printf`. The `\b` word boundary prevents `obsidian-cli-guard`
# or other hyphenated names from tripping the pattern.
#
# stdin  : {"tool_name":"Bash","tool_input":{"command":string},...}
# stdout : {"hookSpecificOutput":{"hookEventName":"PreToolUse",
#            "permissionDecision":"deny",
#            "permissionDecisionReason":string}}
#          | {}   // no decision; defer to permissions
# exit   : 0 on every invocation
set -euo pipefail

emit_decision() {
  local decision="$1" reason="$2"
  jq -n --arg d "$decision" --arg r "$reason" \
    '{hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:$d,permissionDecisionReason:$r}}'
  exit 0
}

emit_defer() {
  printf '{}\n'
  exit 0
}

main() {
  if ! input=$(cat); then
    emit_defer
  fi
  if ! cmd=$(printf '%s' "$input" | jq -r '.tool_input.command // empty'); then
    emit_defer
  fi
  [[ -n "$cmd" ]] || emit_defer

  # obsidian-cli must appear at a segment start so quoted uses like
  # `echo "obsidian-cli create --help"` (where it is an argument to another
  # command) are not matched. `\b` prevents `obsidian-cli-guard` or any
  # other hyphenated binary from triggering the pattern.
  #
  # After the subcommand token (`\S+`), `[^;&|()]*` allows key=value arguments
  # before the offending flag but stops at shell operators (`;`, `&`, `|`, `(`,
  # `)`) so flags on a chained command like `obsidian-cli create path=X && ls -la`
  # are not mistaken for flags on obsidian-cli itself. `\s+-` anchors the
  # dash-prefixed token to a whitespace boundary so a flag embedded in a
  # key=value string is not caught.
  local pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+\S+[^;&|()]*\s+-"

  if printf '%s' "$cmd" | grep -qP "$pattern"; then
    emit_decision "deny" "obsidian-cli does not parse GNU-style flags — dash-prefixed tokens such as --help or --vault are silently ignored, not treated as options. On the create subcommand this causes the CLI to create Untitled.md in the vault and return a misleading success message instead of failing. Use positional key=value arguments for all options (e.g. vault=MyVault path=Notes/Foo.md). Run obsidian-cli help <subcommand> to see the accepted key=value parameters for a given subcommand."
  fi

  # When `obsidian-cli create` is called without any of the recognised target
  # arguments (path=, name=, or file=), the CLI silently writes Untitled.md
  # instead of failing. The negative lookahead `(?![^|><;&]*(?:^|\s)(?:path|name|file)=)`
  # scans only to the first shell operator boundary (`[^|><;&]*`) so that target
  # tokens on a chained command (e.g. `obsidian-cli create | grep path=X`) are
  # not mistaken for a target on this create call. `2>&1` contains `>` which
  # terminates the scan correctly — that redirection is not a target token.
  # `(?:^|\s)` is used instead of `\b` because `\b` matches at a quote-letter
  # transition, so `path=` inside a quoted value like content="path=fake" would
  # be mistaken for a real target argument.
  local no_target_pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+create\b(?![^|><;&]*(?:^|\s)(?:path|name|file)=)"

  if printf '%s' "$cmd" | grep -qP "$no_target_pattern"; then
    emit_decision "deny" "obsidian-cli create requires a target argument: pass path=<vault-relative-path> (e.g. path=Notes/Foo.md). Without path=, name=, or file=, the CLI writes Untitled.md to the vault root and reports success, causing a spurious file that must be manually deleted."
  fi

  # When both name= and path= are supplied and either value contains a dot,
  # the CLI treats path= as a directory prefix and name= as the filename.
  # A dot in the name= value (typical of Foo.md) then nests the file inside a
  # directory whose name is the dot-bearing string, producing unexpected paths
  # like Notes/Foo.md/Foo.md. The same nesting occurs when path= itself contains
  # a dot. The value-with-dot pattern uses alternation to handle quoted values
  # ("Foo.md"), single-quoted values, and bare unquoted values separately so
  # that the leading quote character is consumed before scanning for a dot,
  # avoiding false matches on the quote itself.
  local name_path_dot_pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+create\b(?=[^|><;&]*(?:^|\s)name=)(?=[^|><;&]*(?:^|\s)path=)(?=[^|><;&]*(?:(?:^|\s)name=(?:\"[^\"]*\.[^\"]*\"|'[^']*\.[^']*'|[^\"'\s|><;&]*\.[^\"'\s|><;&]*)|(?:^|\s)path=(?:\"[^\"]*\.[^\"]*\"|'[^']*\.[^']*'|[^\"'\s|><;&]*\.[^\"'\s|><;&]*)))"

  if printf '%s' "$cmd" | grep -qP "$name_path_dot_pattern"; then
    emit_decision "deny" "combining name= and path= with a dot in either value causes directory nesting: the CLI treats path= as a directory prefix and name= as the filename, so a dot-bearing name like Foo.md becomes a subdirectory, producing paths such as Notes/Foo.md/Foo.md. Pass path= alone with the full vault-relative path (e.g. path=Notes/Foo.md) to avoid this."
  fi

  # When `obsidian-cli delete` is called without a target argument (path= or
  # file=), the CLI silently deletes whichever note is currently active in the
  # running Obsidian instance. The deletion is not surfaced until missing content
  # is noticed — a serious, invisible data-loss footgun.
  #
  # The negative lookahead uses `(?:^|\s)` before each key name rather than `\b`
  # to enforce argument-position: `\b` matches at the start of `path=` even
  # inside a quoted value like content="path=fake", because the preceding `"` is
  # a non-word character. Requiring whitespace (or start-of-string) ensures only
  # standalone `path=` and `file=` tokens count as targets.
  local delete_no_target_pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+delete\b(?![^|><;&]*(?:^|\s)(?:path|file)=)"

  if printf '%s' "$cmd" | grep -qP "$delete_no_target_pattern"; then
    emit_decision "deny" "obsidian-cli delete requires a target argument: pass path=<vault-relative-path> (e.g. path=Notes/Foo.md) or file=<name>. Without path= or file=, the CLI silently deletes the active note in the running Obsidian instance — the deletion is invisible until missing content surfaces."
  fi

  # When `obsidian-cli rename` is called with a name= value that does not end
  # in `.md`, the CLI treats the segment after the last dot as the file
  # extension — so "Notes v1.draft" yields extension "draft", and "Bar"
  # (no dot) yields no extension at all. Obsidian cannot index files without
  # the .md extension, and backlinks break silently.
  #
  # The three value alternatives handle double-quoted, single-quoted, and bare
  # unquoted forms separately. The unquoted alternative uses [^"'\s]* rather
  # than \S* so that a quoted value like name="Foo.md" is not consumed as a
  # bare token whose last char is `"` — which would bypass the (?<!\.md) check.
  # (?<!\.md) is a lookbehind anchored to the end of the value (before the
  # closing quote, or before whitespace/end-of-string for unquoted values).
  # (?:^|\s)name= enforces argument position: name= inside a quoted value of
  # another argument (e.g. content="name=ignored") is not matched because the
  # preceding character is `"`, not whitespace.
  local rename_name_md_pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+rename\b[^|><;&]*(?:^|\s)name=(?:\"[^\"]*(?<!\.md)\"|'[^']*(?<!\.md)'|[^\"'\s]*(?<!\.md)(?=\s|$))"

  if printf '%s' "$cmd" | grep -qP "$rename_name_md_pattern"; then
    emit_decision "deny" "obsidian-cli rename requires name= to end with .md. The CLI treats the segment after the last dot as the file extension, so a name like \"Notes v1.draft\" produces extension \"draft\", and a name with no dot at all produces no extension. Without the .md extension Obsidian cannot index the file and backlinks break. Always end the name= value with .md, for example name=\"Notes v1.draft.md\"."
  fi

  # When the first token after `obsidian-cli` is not a recognised subcommand,
  # the CLI silently does nothing useful (or errors in an opaque way). Agents
  # have historically invented subcommands that look plausible but do not exist
  # (e.g. `headings` instead of `outline`, `wikilinks` instead of `links`).
  # Each such invocation wastes one full tool-call turn.
  #
  # A token of the form `[a-z][a-z0-9_]*=` is a key=value argument, which means
  # the subcommand was omitted entirely — that is a different (out-of-scope) case;
  # defer so the agent sees the CLI's own error message.
  #
  # `obsidian-cli` with no following token (help printed by CLI) also defers.
  #
  # The allow-list is space-padded so membership tests use bash substring matching:
  #   [[ " $KNOWN_SUBCOMMANDS " == *" $token "* ]]
  # Sorted alphabetically; reproduced verbatim from `obsidian-cli help` output.
  local KNOWN_SUBCOMMANDS=" aliases append backlinks base:create base:query base:views bases command commands create deadends delete dev:cdp dev:console dev:css dev:debug dev:dom dev:errors dev:mobile dev:screenshot devtools diff eval file files folder folders help history history:list history:open history:read history:restore homepage homepage:read hotkey hotkeys links move open orphans outline plugin plugin:disable plugin:enable plugin:install plugin:reload plugins plugins:enabled plugins:restrict plugin:uninstall prepend properties property:read property:remove property:set random random:read read recents reload rename restart search search:context search:open snippet:disable snippet:enable snippets snippets:enabled tab:open tabs tag tags task tasks theme theme:install themes theme:set theme:uninstall unique unresolved vault vaults version wordcount workspace "

  # Extract the first subcommand-shaped token after `obsidian-cli` at a segment
  # start. \K resets the match start so grep -oP returns only the token itself,
  # avoiding a variable-length lookbehind and its 99-char cap. The character class
  # [a-z][a-z0-9:_-]* cannot contain `=`, so a bare `key=value` first argument
  # yields only the key portion (e.g. `vault` from `vault=Knowledge`). A follow-up
  # check detects that shape by testing whether the candidate is immediately followed
  # by `=` in the original command; if so the subcommand was omitted — defer.
  # Synonym table: known agent footguns mapped to the correct subcommand.
  # Additions here should be paired with a new deny-reason test above.
  local candidate suggested_subcommand
  local segment_pattern="(?:^|[;(]|&&|\|\|)\s*obsidian-cli\b\s+\K[a-z][a-z0-9:_-]*"
  if candidate=$(printf '%s' "$cmd" | grep -oP "$segment_pattern" | head -1) \
      && [[ -n "$candidate" ]] \
      && ! printf '%s' "$cmd" | grep -qP "obsidian-cli\b\s+${candidate}=" \
      && [[ " $KNOWN_SUBCOMMANDS " != *" $candidate "* ]]; then
    case "$candidate" in
      list-vaults)  suggested_subcommand="vaults" ;;
      headings)     suggested_subcommand="outline" ;;
      wikilinks)    suggested_subcommand="links" ;;
      frontmatter)  suggested_subcommand="properties" ;;
      tag:files)    suggested_subcommand="tag" ;;
      *)            suggested_subcommand="" ;;
    esac

    if [[ -n "$suggested_subcommand" ]]; then
      emit_decision "deny" "\"$candidate\" is not a recognised obsidian-cli subcommand. Did you mean \"$suggested_subcommand\"? Use: obsidian-cli $suggested_subcommand"
    else
      emit_decision "deny" "\"$candidate\" is not a recognised obsidian-cli subcommand. Use: obsidian-cli <subcommand>. Run \`obsidian-cli help\` for the full list."
    fi
  fi

  emit_defer
}

main || printf '{}\n'
exit 0
