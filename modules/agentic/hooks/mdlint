#!/usr/bin/env bash
# PreToolUse hook: markdown linter
# Blocks Edit/Write on *.md files that introduce rule violations.
# Only new content is checked (new_string for Edit, content for Write);
# pre-existing violations in unchanged file regions are not re-examined.
# See .agents/prd-markdown.md
#
# Rules:
#   emoji              — block any unicode emoji codepoint
#   enumerated-heading — block headings whose text starts with a digit followed by
#                        optional dot and whitespace (e.g. "# 1. Title", "# 2 Title")
#   bold-only-heading  — block headings whose entire visible text is wrapped in
#                        **...** or __...__ (e.g. "# **Introduction**")
#   unescaped-dollar   — block $ not preceded by \ outside fenced code blocks
#   verbose-constructions (soft) — warn on wordy phrases without blocking
#   all-caps (soft)      — warn on lines that are entirely uppercase and longer than 20 chars
#
# Warn-only mechanism (resolved from Open Question 1 in .agents/prd-markdown.md):
#   Soft rules write {"hookSpecificOutput":{"hookEventName":"PreToolUse",
#   "additionalContext":"..."}} to stdout and exit 0. Claude sees additionalContext
#   as a system reminder in subsequent turns; the tool call is not blocked.
#
# stdin  : Claude Code PreToolUse JSON
# stdout : {"decision":"block","reason":string}             on hard violation (exit 2)
#        | {"hookSpecificOutput":{"hookEventName":"PreToolUse","additionalContext":string}}
#                                                           on soft match (exit 0)
#        | (empty)                                          on no violation (exit 0)
set -euo pipefail

if ! input=$(cat); then
  exit 0
fi

if ! file_path=$(printf '%s' "$input" | jq -r '.tool_input.file_path // ""'); then
  exit 0
fi
if ! tool_name=$(printf '%s' "$input" | jq -r '.tool_name // ""'); then
  exit 0
fi

# Short-circuit for non-markdown paths.
[[ "$file_path" == *.md ]] || exit 0

case "$tool_name" in
  Edit)  content_field="new_string" ;;
  Write) content_field="content" ;;
  *)     exit 0 ;;
esac

# Extract new content.
if ! new_content=$(printf '%s' "$input" | jq -r --arg field "$content_field" '.tool_input[$field] // empty'); then
  exit 0
fi
[[ -n "$new_content" ]] || exit 0

# Enumerated-heading rule: block headings whose visible text starts with a digit.
# The pattern is line-anchored: the heading marker (^#+ ) must be immediately
# followed by the digit sequence, so body paragraphs containing "1." are unaffected.
# The trailing [[:space:]] is required so bare-number headings (e.g. "# 1") are
# not matched; such headings are not considered enumerated by this rule.
# Runs before the emoji rule because ERE is cheaper than PCRE.
# See .agents/prd-markdown.md
# grep exits 0 on match, 1 on no match, 2+ on error (e.g. PCRE unavailable).
# The || prevents set -e from aborting; grep_status distinguishes the cases.
enum_status=0
enum_line=$(printf '%s' "$new_content" | grep -Em1 '^#+ [0-9]+\.?[[:space:]]') || enum_status=$?
if [[ $enum_status -ge 2 ]]; then
  printf 'mdlint: grep error (exit %d)\n' "$enum_status" >&2
  exit 0
fi
if [[ $enum_status -eq 0 ]]; then
  jq -n --arg reason "enumerated heading rule violation: ${enum_line}" \
    '{"decision":"block","reason":$reason}'
  exit 2
fi

# Bold-only heading rule: block headings whose entire visible text is wrapped
# in **...** or __...__.  Partial bold (e.g. "## Step **two** is hard") and
# non-heading lines are unaffected because the pattern is line-anchored and
# requires the bold markers to immediately follow the heading prefix.
# [^*]+ / [^_]+ (rather than .*) prevents matching across multiple bold spans:
# "# **one** and **two**" would otherwise match from the first ** to the last.
# See .agents/prd-markdown.md and .agents/issues/03-block-bold-only-headings.md
bold_re='^#+[[:space:]]+\*\*[^*]+\*\*[[:space:]]*$|^#+[[:space:]]+__[^_]+__[[:space:]]*$'
bold_status=0
bold_line=$(printf '%s' "$new_content" | grep -Em1 "$bold_re") || bold_status=$?
if [[ $bold_status -ge 2 ]]; then
  printf 'mdlint: grep error (exit %d)\n' "$bold_status" >&2
  exit 0
fi
if [[ $bold_status -eq 0 ]]; then
  jq -n --arg reason "bold-only heading rule violation: ${bold_line}" \
    '{"decision":"block","reason":$reason}'
  exit 2
fi

# Unescaped dollar sign rule: block $ not preceded by \ outside fenced code blocks.
# Uses a line-by-line scan to track fence state across the new content.
# Both backtick (```) and tilde (~~~) fences are recognised. A fence is only
# closed by the same character that opened it (CommonMark rule).
# Inline code spans are not exempted — escape $ even inside backticks.
# False-positive: new_string that is entirely inside a pre-existing fence looks
# like plain text to this hook; see .agents/issues/04-block-unescaped-dollar-signs.md.
# See .agents/prd-markdown.md
fence_re='^[[:space:]]*(```+|~~~+)'
fence_char=""
in_fence=0
dollar_line=""
while IFS= read -r line; do
  if [[ "$line" =~ $fence_re ]]; then
    opening_char="${BASH_REMATCH[1]:0:1}"
    if [[ $in_fence -eq 0 ]]; then
      in_fence=1
      fence_char="$opening_char"
    elif [[ "$opening_char" == "$fence_char" ]]; then
      in_fence=0
      fence_char=""
    fi
    continue
  fi
  if [[ $in_fence -eq 0 ]]; then
    dollar_exit=0
    # Parity-aware lookbehind: match $ not preceded by an unescaped backslash.
    # (?<!(?<!\\)\\) — outer: not preceded by an unescaped \; inner: \ not
    # preceded by \. Correctly handles \$ (pass), \\$ (block). Known limitation:
    # \\\$ (triple backslash + dollar) incorrectly blocks; this edge case is
    # accepted as it does not arise in normal markdown prose.
    printf '%s\n' "$line" | grep -qP '(?<!(?<!\\)\\)\$' || dollar_exit=$?
    if [[ $dollar_exit -ge 2 ]]; then
      printf 'mdlint: grep error (exit %d)\n' "$dollar_exit" >&2
      exit 0
    fi
    if [[ $dollar_exit -eq 0 ]]; then
      dollar_line="$line"
      break
    fi
  fi
done <<< "$new_content"
if [[ -n "$dollar_line" ]]; then
  jq -n --arg reason "unescaped dollar sign rule violation: ${dollar_line}" \
    '{"decision":"block","reason":$reason}'
  exit 2
fi

# Emoji rule: block any unicode emoji codepoint.
# Core blocks: Emoticons (U+1F600-U+1F64F), Misc Symbols and Pictographs
# (U+1F300-U+1F5FF), Transport and Map (U+1F680-U+1F6FF), Supplemental Symbols
# and Pictographs (U+1F900-U+1F9FF), Symbols and Pictographs Extended-A
# (U+1FA00-U+1FAFF), Regional Indicators (U+1F1E0-U+1F1FF), Dingbats
# (U+2700-U+27BF), Misc Symbols (U+2600-U+26FF).
# Additional scattered codepoints: Mahjong/Joker (U+1F004, U+1F0CF), Enclosed
# Ideographic Supplement (U+1F200-U+1F2FF), clocks and media controls
# (U+231A-U+231B, U+23CF, U+23E9-U+23F3, U+23F8-U+23FA), geometric shapes used
# as emoji (U+25AA-U+25AB, U+25B6, U+25C0, U+25FB-U+25FE), and arrows/stars in
# Misc Symbols and Arrows (U+2B05-U+2B07, U+2B1B-U+2B1C, U+2B50, U+2B55).
# See .agents/prd-markdown.md
emoji_re='[\x{1F600}-\x{1F64F}\x{1F300}-\x{1F5FF}\x{1F680}-\x{1F6FF}\x{1F1E0}-\x{1F1FF}\x{1F900}-\x{1F9FF}\x{1FA00}-\x{1FA6F}\x{1FA70}-\x{1FAFF}\x{1F004}\x{1F0CF}\x{1F200}-\x{1F2FF}\x{2600}-\x{26FF}\x{2700}-\x{27BF}\x{231A}-\x{231B}\x{23CF}\x{23E9}-\x{23F3}\x{23F8}-\x{23FA}\x{24C2}\x{25AA}-\x{25AB}\x{25B6}\x{25C0}\x{25FB}-\x{25FE}\x{2B05}-\x{2B07}\x{2B1B}-\x{2B1C}\x{2B50}\x{2B55}]'

grep_status=0
offending_line=$(printf '%s' "$new_content" | grep -Pm1 "$emoji_re") || grep_status=$?
if [[ $grep_status -ge 2 ]]; then
  printf 'mdlint: grep error (exit %d)\n' "$grep_status" >&2
  exit 0
fi
if [[ $grep_status -eq 0 ]]; then
  jq -n --arg reason "no-emoji rule violation: ${offending_line}" \
    '{"decision":"block","reason":$reason}'
  exit 2
fi

# ALL-CAPS shouting rule (soft): warn on lines that are predominantly ALL-CAPS.
# A line qualifies when: it contains ≥1 alphabetic char, all alpha chars are
# uppercase, and its length is >20 chars.
# Exclusions applied in order:
#   label prefix — lines beginning with TODO/NOTE/WARNING/IMPORTANT/CRITICAL/UNVERIFIED
#   bare acronyms — all alpha tokens ≤5 chars (covers the short RFC 2119 keywords MUST, SHALL, MAY, NOT
#                   and common abbreviations: HTTP, JSON, API, URL, XML, REST, …)
# Mixed-case RFC 2119 text (e.g. "The server MUST return…") and mixed-case
# sentences containing acronyms are naturally excluded because the lowercase
# letters fail the all-alpha-uppercase check before any exclusion is tested.
# See .agents/prd-markdown.md
fence_char=""
in_fence=0
caps_match=""
while IFS= read -r line; do
  if [[ "$line" =~ $fence_re ]]; then
    opening_char="${BASH_REMATCH[1]:0:1}"
    if [[ $in_fence -eq 0 ]]; then
      in_fence=1
      fence_char="$opening_char"
    elif [[ "$opening_char" == "$fence_char" ]]; then
      in_fence=0
      fence_char=""
    fi
    continue
  fi
  [[ $in_fence -eq 0 ]] || continue

  # Short-line exclusion: lines ≤20 chars cannot be predominantly ALL-CAPS.
  [[ ${#line} -gt 20 ]] || continue

  # Must contain at least one alphabetic character.
  has_alpha_exit=0
  printf '%s\n' "$line" | grep -qP '[[:alpha:]]' || has_alpha_exit=$?
  if [[ $has_alpha_exit -ge 2 ]]; then
    printf 'mdlint: grep error (exit %d)\n' "$has_alpha_exit" >&2
    break
  fi
  if [[ $has_alpha_exit -ne 0 ]]; then
    continue
  fi

  # All alphabetic characters must be uppercase (no lowercase allowed).
  lc_exit=0
  printf '%s\n' "$line" | grep -qP '[a-z]' || lc_exit=$?
  if [[ $lc_exit -ge 2 ]]; then
    printf 'mdlint: grep error (exit %d)\n' "$lc_exit" >&2
    break
  fi
  if [[ $lc_exit -eq 0 ]]; then
    continue
  fi

  # Label keyword exclusion.
  label_exit=0
  printf '%s\n' "$line" | grep -qP '^(TODO|NOTE|WARNING|IMPORTANT|CRITICAL|UNVERIFIED)([^[:alpha:]]|$)' || label_exit=$?
  if [[ $label_exit -ge 2 ]]; then
    printf 'mdlint: grep error (exit %d)\n' "$label_exit" >&2
    break
  fi
  if [[ $label_exit -eq 0 ]]; then
    continue
  fi

  # Bare-acronym exclusion: skip if every alpha token is ≤5 characters.
  all_acronyms=1
  while IFS= read -r token; do
    if [[ ${#token} -gt 5 ]]; then
      all_acronyms=0
      break
    fi
  done < <(printf '%s\n' "$line" | grep -oP '[[:alpha:]]+')
  if [[ $all_acronyms -eq 1 ]]; then
    continue
  fi

  caps_match="$line"
  break
done <<< "$new_content"
if [[ -n "$caps_match" ]]; then
  jq -n \
    --arg ctx "all-caps rule: shouting detected in: ${caps_match}" \
    '{"hookSpecificOutput":{"hookEventName":"PreToolUse","additionalContext":$ctx}}'
  exit 0
fi

# Verbose-constructions rule (soft): warn on wordy phrases without blocking.
# Phrases (case-insensitive, \b-anchored): "the fact that", "in many cases",
# "very", "owing to the fact that", "character of", "nature of".
# If a shorter phrase is a word-boundary-aligned prefix of a longer one,
# list the longer phrase first so the full phrase is captured by grep -o.
# Emits hookSpecificOutput.additionalContext and exits 0 — the tool call proceeds.
# See .agents/prd-markdown.md
verbose_re='\b(owing to the fact that|the fact that|in many cases|character of|nature of|very)\b'
verbose_match=""
verbose_phrase=""
while IFS= read -r line; do
  v_exit=0
  matched=$(printf '%s\n' "$line" | grep -ioPm1 "$verbose_re") || v_exit=$?
  if [[ $v_exit -ge 2 ]]; then
    printf 'mdlint: grep error (exit %d)\n' "$v_exit" >&2
    break
  fi
  if [[ $v_exit -eq 0 ]]; then
    verbose_match="$line"
    # Lowercase so the warning names the canonical phrase regardless of input case.
    verbose_phrase=$(printf '%s' "$matched" | tr '[:upper:]' '[:lower:]')
    break
  fi
done <<< "$new_content"
if [[ -n "$verbose_match" ]]; then
  jq -n \
    --arg ctx "verbose-constructions rule: phrase '${verbose_phrase}' in: ${verbose_match}" \
    '{"hookSpecificOutput":{"hookEventName":"PreToolUse","additionalContext":$ctx}}'
fi
